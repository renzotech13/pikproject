# PIK — variables de entorno (demo)
# Las integraciones reales están MOCKEADAS. Estas claves quedan documentadas
# para el día que se conecten servicios reales (ver CONTRACT.md > "Capa de servicios").

# Modo de datos: "mock" (default) | "api"
VITE_DATA_SOURCE=mock

# Latencia simulada para los servicios mock (ms)
VITE_MOCK_LATENCY=600

# Placeholders de integraciones futuras (NO usadas en la demo)
VITE_API_BASE_URL=
VITE_PAYMENTS_PROVIDER=          # culqi | niubiz | mercadopago
VITE_MAPS_API_KEY=
